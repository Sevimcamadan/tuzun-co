<header>
  <a class="header__title" href="{{ routes.root_url }}">Tuzun</a>

  {%- if section.settings.menu != blank -%}
    <nav class="header__nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a
          class="header__nav-link{% if link.active %} is-active{% endif %}"
          href="{{ link.url }}"
        >
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>
  {%- endif -%}
</header>

{% stylesheet %}
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin);
    background: transparent;
  }

  .header__title {
    font-size: 1rem;
    font-weight: 400;
    color: #000;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .header__nav-link {
    font-size: 1rem;
    font-weight: 400;
    color: #000;
    text-decoration: none;
    letter-spacing: 0.05em;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    opacity: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
