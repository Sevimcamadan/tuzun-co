<header>
  <span class="header__title">Tuzun</span>
</header>

{% stylesheet %}
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 5rem;
    display: flex;
    align-items: center;
    padding: 0 var(--page-margin);
    background: transparent;
  }
  .header__title {
    font-size: 1rem;
    font-weight: 400;
    color: #000;
    letter-spacing: 0.05em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header"
}
{% endschema %}
