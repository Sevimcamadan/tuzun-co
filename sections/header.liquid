<header>
  <a class="header__title" href="{{ routes.root_url }}">
    <img
      src="{{ 'Tuzun-Logo.png' | asset_url }}"
      alt="Tuzun"
      width="2732"
      height="2048"
      class="header__logo"
    >
  </a>
</header>

{% stylesheet %}
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 5rem;
    display: flex;
    align-items: center;
    padding: 0 var(--page-margin);
    background: transparent;
  }

  .header__title {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header__logo {
    height: 3rem;
    width: auto;
    display: block;
  }

  @media (max-width: 767px) {
    body {
      padding-top: calc(5rem + 1.5rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": []
}
{% endschema %}
